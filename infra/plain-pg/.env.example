# Local secrets for the plain-PostgreSQL container (SCM-S56).
# Copy this file to infra/plain-pg/.env (which is gitignored) and set a strong password:
#     cp infra/plain-pg/.env.example infra/plain-pg/.env
# Keep this value in sync with the password in the repo-root .env
# (SUPABASE_DB_URL / SUPABASE_POOLER_URL, which point at 127.0.0.1:5433).
SCM_PG_PASSWORD=change-me-to-a-strong-password
