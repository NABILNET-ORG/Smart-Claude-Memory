{
  "_README": "Smart-Claude-Memory MCP server config for Cline (VS Code extension saoudrizwan.claude-dev). Open Cline → MCP Servers icon → Configure → Configure MCP Servers, which opens cline_mcp_settings.json. Default path on Windows: %APPDATA%\\Code\\User\\globalStorage\\saoudrizwan.claude-dev\\settings\\cline_mcp_settings.json. See docs/IDE-INTEGRATION.md § Cline (VS Code) for the platform-specific path on macOS/Linux and the VS Code Insiders / VSCodium variant.",
  "mcpServers": {
    "smart-claude-memory": {
      "command": "node",
      "args": [
        "C:/absolute/path/to/Claude-Memory/dist/index.js"
      ],
      "env": {
        "SUPABASE_URL": "https://<your-ref>.supabase.co",
        "SUPABASE_SECRET_KEY": "<service_role_key>",
        "SUPABASE_POOLER_URL": "<pooler_url_or_db_url>",
        "OLLAMA_HOST": "http://127.0.0.1:11434",
        "OLLAMA_EMBED_MODEL": "nomic-embed-text",
        "EMBED_DIM": "768",
        "MEMORY_ROOTS": "C:/absolute/path/to/notes_or_repo"
      },
      "disabled": false,
      "autoApprove": []
    }
  }
}
