# Database — plain PostgreSQL 17 + pgvector (local; see infra/plain-pg/docker-compose.yml).
# (The variable NAMES keep the historical SUPABASE_ prefix; they now point at the plain local DB.)
SUPABASE_DB_URL=postgresql://postgres:<password>@127.0.0.1:5433/postgres
SUPABASE_POOLER_URL=postgresql://postgres:<password>@127.0.0.1:5433/postgres

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# Memory sync (semicolon-separated paths)
MEMORY_ROOTS=/path/to/notes;/another/path
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# v1.1.0 Smart Claude Memory Sovereign Orchestrator — enables hard-block hook + self-healing defaults
SMART_CLAUDE_MEMORY_ORCHESTRATOR_MODE=1

# v1.1.0 — max raw lines the main session may see from a single tool result before being truncated by the context-hygiene layer
SMART_CLAUDE_MEMORY_LINE_LIMIT=750
