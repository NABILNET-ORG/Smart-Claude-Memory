# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# Transaction pooler (IPv4-reachable). Get from Supabase dashboard > Settings > Database > Connection pooler.
# Required if your network has no IPv6 route to the direct DB host.
SUPABASE_POOLER_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# Memory sync (semicolon-separated paths)
MEMORY_ROOTS=/path/to/notes;/another/path
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# v1.1.0 Smart Claude Memory Sovereign Orchestrator — enables hard-block hook + self-healing defaults
SMART_CLAUDE_MEMORY_ORCHESTRATOR_MODE=1

# v1.1.0 — max raw lines the main session may see from a single tool result before being truncated by the context-hygiene layer
SMART_CLAUDE_MEMORY_LINE_LIMIT=750
